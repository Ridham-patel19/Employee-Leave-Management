  "//Login Controller": {
    "prefix": "//loginctrl",
    "body": [
      "public IActionResult Login()",
      "{",
      "    HttpContext.Session.Clear();",
      "    return View();",
      "}",
      "",
      "[HttpPost]",
      "public async Task<IActionResult> Login(vm_login logindata)",
      "{",
      "    if (!ModelState.IsValid)",
      "    {",
      "        return BadRequest(new { success = false, message = \"Invalid Data\" });",
      "    }",
      "",
      "    var userdata = await _authrepo.Login(logindata);",
      "",
      "    if (userdata == null)",
      "    {",
      "        return Unauthorized(new { success = false, message = \"Invalid email or password\" });",
      "    }",
      "",
      "    HttpContext.Session.SetInt32(\"userid\", userdata.userid);",
      "    HttpContext.Session.SetString(\"username\", userdata.name);",
      "    HttpContext.Session.SetString(\"role\", userdata.role);",
      "",
      "    return Ok(new { success = true, message = \"Login Successfully\" });",
      "}"
    ],
    "description": "Login Controller"
  },
  "//Register Controller": {
    "prefix": "//registerctrl",
    "body": [
      "public IActionResult Register()",
      "{",
      "    return View();",
      "}",
      "",
      "[HttpPost]",
      "public async Task<IActionResult> Register(User userdata)",
      "{",
      "    if (!ModelState.IsValid)",
      "    {",
      "        return Json(new { success = false, message = \"Invalid Data\" });",
      "    }",
      "",
      "    if (userdata.imgfile != null && userdata.imgfile.Length > 0)",
      "    {",
      "        string folder = Path.Combine(Directory.GetCurrentDirectory(), \"wwwroot\", \"images\");",
      "        if (!Directory.Exists(folder)) Directory.CreateDirectory(folder);",
      "",
      "        string filename = Guid.NewGuid().ToString() + Path.GetExtension(userdata.imgfile.FileName);",
      "        string path = Path.Combine(folder, filename);",
      "",
      "        using (var stream = new FileStream(path, FileMode.Create))",
      "        {",
      "            await userdata.imgfile.CopyToAsync(stream);",
      "        }",
      "",
      "        userdata.imgstr = filename;",
      "    }",
      "",
      "    int result = await _authrepo.Register(userdata);",
      "",
      "    if (result == 0) return Json(new { success = false, message = \"User already exists\" });",
      "    if (result == -1) return Json(new { success = false, message = \"Unable to register\" });",
      "",
      "    return Json(new { success = true, message = \"Registered Successfully\" });",
      "}"
    ],
    "description": "Register Controller"
  },
