      "        var qry = \"INSERT INTO t_user (c_name, c_email, c_password, c_mobile, c_gender, c_country, c_imgstr, c_createdat, c_role) VALUES (@c_name, @c_email, @c_password, @c_mobile, @c_gender, @c_country, @c_imgstr, @c_createdat, @c_role)\";",
      "",
      "        try",
      "        {",
      "            using(NpgsqlCommand cm = new NpgsqlCommand(qry , _conn))",
      "            {",
      "                cm.Parameters.AddWithValue(\"c_name\",userdata.name);",
      "                cm.Parameters.AddWithValue(\"c_email\",userdata.email);",
      "                cm.Parameters.AddWithValue(\"c_password\",userdata.password);",
