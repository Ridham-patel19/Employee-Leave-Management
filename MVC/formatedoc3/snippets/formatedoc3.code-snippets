      "}",
      "",
      "<div id=\"grid\"></div>",
      "<div id=\"notification\"></div>",
      "",
      "<!-- Gender Radio Button Editor Template -->",
      "<script id=\"gender-editor-template\" type=\"text/x-kendo-template\">",
      "    <div class=\"gender-radio-group\">",
      "        <label><input type=\"radio\" name=\"gender\" value=\"Male\" #= data.gender === 'Male' ? 'checked' : '' #> Male</label>",
      "        <label><input type=\"radio\" name=\"gender\" value=\"Female\" #= data.gender === 'Female' ? 'checked' : '' #> Female</label>",
      "        <label><input type=\"radio\" name=\"gender\" value=\"Other\" #= data.gender === 'Other' ? 'checked' : '' #> Other</label>",
      "    </div>",
      "</script>",
      "",
      "@section Scripts{",
      "    <script>",
      "        $(document).ready(function(){",
      "",
      "            var dataSource=new kendo.data.DataSource({ ",
      "                transport:{ ",
      "                    read:{ url:\"/Admin/GetAllUsers\", dataType:\"json\" },",
      "                    create:{ url:\"/Admin/AddUser\", dataType:\"json\", type:\"POST\", contentType:\"application/json\" },",
      "                    update:{ url:\"/Admin/UpdateUser\", dataType:\"json\", type:\"POST\", contentType:\"application/json\" },",
      "                    destroy:{ url:\"/Admin/DeleteUser\", dataType:\"json\", type:\"POST\", contentType:\"application/json\" },",
      "",
      "                    parameterMap: function (data, type) {",
      "                        if (type === \"create\" || type === \"update\") {",
      "                            var model = data.models ? data.models[0] : data;",
      "",
      "                            var mappedData = {",
      "                                userid: model.userid == null ? 0 : model.userid,",
      "                                name: model.name,",
      "                                email: model.email,",
