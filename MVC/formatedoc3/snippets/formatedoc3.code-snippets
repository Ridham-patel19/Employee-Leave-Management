  "//User Model": {
    "prefix": "//usermodel",
    "body": [
      "public class User",
      "{",
      "    [Key]",
      "    [DatabaseGenerated(DatabaseGeneratedOption.Identity)]",
      "    public int userid { get; set; }",
      "",
      "    [Required(ErrorMessage = \"Name is required\")]",
      "    [Display(Name = \"Full Name\")]",
      "    [StringLength(100, MinimumLength = 2, ErrorMessage = \"Name must be between 2 to 100 characters\")]",
      "    public string name { get; set; }",
      "",
      "    [Required(ErrorMessage = \"Email is required\")]",
      "    [Display(Name = \"Email Address\")]",
      "    [EmailAddress(ErrorMessage = \"Enter a valid email\")]",
      "    [StringLength(150)]",
      "    public string email { get; set; }",
      "",
      "    [Required(ErrorMessage = \"Password is required\")]",
      "    [Display(Name = \"Password\")]",
      "    [DataType(DataType.Password)]",
      "    [RegularExpression(@\"^(?=.*[a-z])(?=.*[A-Z])(?=.*\\\\d)(?=.*[\\\\W_]).{6,}$\", ErrorMessage = \"Password must have uppercase, lowercase, number, special character and min 6 length\")]",
      "    public string password { get; set; }",
      "",
      "    [Required(ErrorMessage = \"Mobile number is required\")]",
      "    [Display(Name = \"Mobile Number\")]",
      "    [RegularExpression(@\"^[6-9]\\\\d{9}$\", ErrorMessage = \"Enter valid 10-digit mobile number\")]",
      "    public string mobile { get; set; }",
      "",
      "    [Required(ErrorMessage = \"Gender is required\")]",
      "    [Display(Name = \"Gender\")]",
      "    public string gender { get; set; }",
      "",
      "    [Required(ErrorMessage = \"Country is required\")]",
      "    [Display(Name = \"Country\")]",
      "    [StringLength(50)]",
      "    public string country { get; set; }",
      "",
      "    [Display(Name = \"Created At\")]",
      "    public DateTime createdat { get; set; }",
      "",
      "    [Display(Name = \"Profile Image\")]",
      "    public string? imgstr { get; set; }",
      "",
      "    [NotMapped]",
      "    public IFormFile? imgfile { get; set; }",
      "",
      "    [NotMapped]",
      "    public string? role { get; set; } = \"User\";",
      "}"
    ],
    "description": "User Model with DataAnnotations"
  },
  "//Auth Login Repo": {
    "prefix": "//loginrepo",
    "body": [
      "public async Task<User> Login(${1:vm_login} logindata)",
      "{",
      "    User userdata = new User();",
      "",
      "    var qry = \"SELECT c_userid, c_name, c_email, c_password, c_mobile, c_gender, c_country, c_imgstr, c_createdat, c_role FROM t_user WHERE c_email = @c_email AND c_password = @c_password\";",
      "",
      "    try",
      "    {",
      "        using (NpgsqlCommand cm = new NpgsqlCommand(qry , _conn))",
      "        {",
      "            cm.Parameters.AddWithValue(\"c_email\", logindata.Email);",
      "            cm.Parameters.AddWithValue(\"c_password\", logindata.Password);",
      "",
      "            await _conn.OpenAsync();",
      "",
      "            var reader = await cm.ExecuteReaderAsync();",
      "",
      "            if (reader.Read())",
      "            {",
      "                userdata.userid = Convert.ToInt32(reader[\"c_userid\"]);",
      "                userdata.name = reader[\"c_name\"]?.ToString();",
      "                userdata.email = reader[\"c_email\"]?.ToString();",
      "                userdata.password = reader[\"c_password\"]?.ToString();",
      "                userdata.mobile = reader[\"c_mobile\"]?.ToString();",
      "                userdata.gender = reader[\"c_gender\"]?.ToString();",
      "                userdata.country = reader[\"c_country\"]?.ToString();",
      "                userdata.imgstr = reader[\"c_imgstr\"]?.ToString();",
      "                userdata.createdat = ((DateOnly)reader[\"c_createdat\"]).ToDateTime(TimeOnly.MinValue);",
      "                userdata.role = reader[\"c_role\"]?.ToString();",
      "            }",
      "        }",
      "    }",
      "    catch(Exception ex)",
      "    {",
      "        Console.WriteLine(ex.Message);",
      "    }",
      "    finally",
      "    {",
      "        await _conn.CloseAsync();",
      "    }",
      "",
      "    return userdata;",
      "}"
    ],
    "description": "Auth Login Repository with full mapping"
  },
  "//Auth Register Repo": {
    "prefix": "//registerrepo",
    "body": [
      "public async Task<int> Register(${1:User} userdata)",
      "{",
      "    var qrycheck = \"SELECT COUNT(*) FROM t_user WHERE c_email = @c_email\";",
      "",
      "    var qry = \"INSERT INTO t_user (c_name, c_email, c_password, c_mobile, c_gender, c_country, c_imgstr, c_createdat, c_role) VALUES (@c_name, @c_email, @c_password, @c_mobile, @c_gender, @c_country, @c_imgstr, @c_createdat, @c_role)\";",
      "",
      "    try",
      "    {",
      "        using(NpgsqlCommand cmcheck = new NpgsqlCommand(qrycheck , _conn))",
      "        {",
      "            cmcheck.Parameters.AddWithValue(\"c_email\", userdata.email);",
      "",
      "            await _conn.OpenAsync();",
      "",
      "            int result = Convert.ToInt32(await cmcheck.ExecuteScalarAsync());",
      "",
      "            if(result > 0)",
      "            {",
      "                await _conn.CloseAsync();",
      "                return 0;",
      "            }",
      "",
      "            NpgsqlCommand cm = new NpgsqlCommand(qry , _conn);",
      "",
      "            cm.Parameters.AddWithValue(\"c_name\", userdata.name);",
      "            cm.Parameters.AddWithValue(\"c_email\", userdata.email);",
      "            cm.Parameters.AddWithValue(\"c_password\", userdata.password);",
      "            cm.Parameters.AddWithValue(\"c_mobile\", userdata.mobile);",
      "            cm.Parameters.AddWithValue(\"c_gender\", userdata.gender);",
      "            cm.Parameters.AddWithValue(\"c_country\", userdata.country);",
      "            cm.Parameters.AddWithValue(\"c_imgstr\", userdata.imgstr);",
      "            cm.Parameters.AddWithValue(\"c_createdat\", userdata.createdat);",
      "            cm.Parameters.AddWithValue(\"c_role\", \"User\");",
      "",
      "            await cm.ExecuteNonQueryAsync();",
      "",
      "            await _conn.CloseAsync();",
      "            return 1;",
      "        }",
      "    }",
      "    catch(Exception ex)",
      "    {",
      "        Console.WriteLine(ex.Message);",
      "        await _conn.CloseAsync();",
      "        return -1;",
      "    }",
      "}"
    ],
    "description": "Auth Register Repository Method"
  },
  "//loginview": {
    "prefix": "//loginview",
    "body": [
      "@{",
      "    ViewData[\"Title\"] = \"Login\";",
      "}",
      "",
      "<div id=\"validation-success\"></div>",
      "",
      "<div class=\"container mt-5\" style=\"border: 1px solid #ccc; width: 70%; padding:20px\">",
      "    <h3>Login</h3>",
      "    <form id=\"Loginform\"></form>",
      "</div>",
      "",
      "@section Scripts{",
      "<script>",
      "$(document).ready(function () {",
      "    ",
      "    const validationSuccess = $(\"#validation-success\");",
      "",
      "    $(\"#Loginform\").kendoForm({",
      "",
      "        validatable: {",
      "            validateOnBlur: true,",
      "            validationSummary: false,",
      "            errorTemplate: \"<span class='k-form-error'>#:message#</span>\"",
      "        },",
      "",
      "        items: [",
      "",
      "            {",
      "                field: \"Email\",",
      "                label: \"Email:\",",
      "                validation: {",
      "                    required: { message: \"Please enter your email.\" },",
      "                    email: { message: \"Please enter a valid email address.\" }",
      "                }",
      "            },",
      "",
      "            {",
      "                field: \"Password\",",
      "                label: \"Password:\",",
      "                validation: { required: { message: \"Please enter password.\" } },",
      "                editor: function (container, options) {",
      "                    $('<input type=\"password\" name=\"' + options.field + '\" autocomplete=\"off\"/required>')",
      "                        .appendTo(container)",
      "                        .kendoTextBox();",
      "                }",
      "            }",
      "        ],",
      "",
      "        buttonsTemplate:",
      "            '<button type=\"submit\" class=\"k-button k-button-lg k-button-solid-success\">Login</button> ' +",
      "            '<button type=\"button\" id=\"btnClearForm\" class=\"k-button k-button-lg\">Clear</button>',",
      "",
      "        validateField: function () {",
      "            validationSuccess.html(\"\");",
      "        },",
      "",
      "        submit: function (e) {",
      "            e.preventDefault();",
      "",
      "            const LoginData = new FormData();",
      "",
      "            LoginData.append(\"Email\", e.model.Email);",
      "            LoginData.append(\"Password\", e.model.Password);",
      "",
      "            $.ajax({",
      "                url: \"/Auth/Login\",",
      "                method: \"POST\",",
      "                contentType: false,",
      "                processData: false,",
      "                data: LoginData,",
      "",
      "                success: function (result) {",
      "                    validationSuccess.html(",
      "                        \"<div class='k-messagebox k-messagebox-success'><p>\" + result.message + \"</p></div>\"",
      "                    );",
      "",
      "                    setTimeout(() => {",
      "                        window.location.href = \"../Home/Index\";",
      "                    }, 500);",
      "                },",
      "",
      "                error: function (xhr) {",
      "                    let message = \"Something went wrong\";",
      "",
      "                    if (xhr.status === 400) {",
      "                        message = xhr.responseJSON?.message || \"Invalid data\";",
      "                    }",
      "                    else if (xhr.status === 401) {",
      "                        message = xhr.responseJSON?.message || \"Invalid email or password\";",
      "                    }",
      "                    else if (xhr.status === 500) {",
      "                        message = \"Server error\";",
      "                    }",
      "",
      "                    validationSuccess.html(",
      "                        \"<div class='k-messagebox k-messagebox-error'><p>\" + message + \"</p></div>\"",
      "                    );",
      "                }",
      "            });",
      "        }",
      "    });",
      "",
      "    $(document).on(\"click\", \"#btnClearForm\", function () {",
      "        $(\"#Loginform\").data(\"kendoForm\").clear();",
      "        validationSuccess.html(\"\");",
      "    });",
      "});",
      "</script>",
      "}"
    ],
    "description": "Kendo Login View with AJAX"
  },
