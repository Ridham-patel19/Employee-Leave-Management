      "                cm.Parameters.AddWithValue(\"c_createdat\",userdata.createdat);",
      "                cm.Parameters.AddWithValue(\"c_role\",\"User\");",
      "",
      "                await _conn.OpenAsync();",
      "",
      "                await cm.ExecuteNonQueryAsync();",
      "            }",
      "        }",
      "        catch(Exception ex)",
      "        {",
      "            await _conn.CloseAsync();",
