      "    {",
      "        var qry = \"DELETE FROM t_user WHERE c_userid = @c_userid\";",
      "",
      "        try",
      "        {",
      "            using(NpgsqlCommand cm = new NpgsqlCommand(qry , _conn))",
      "            {",
      "                cm.Parameters.AddWithValue(\"c_userid\",userid);",
      "",
      "                await _conn.OpenAsync();",
      "",
      "                await cm.ExecuteNonQueryAsync();",
      "            }",
      "        }",
